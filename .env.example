# Core
DEV_MODE=false
DISCORD_APPLICATION_ID=? # Discord Application ID
DISCORD_BOT_TOKEN=? # Discord Bot Token
MANAGER_ROLE_NAMES= # Optional comma-separated manager role names

# Application
CALL_IN_HOST_CHANNEL_NAME=? # Private call-in host channel name
CALL_IN_HOST_ROLE_NAMES=? # Comma-separated call-in host role names
CHATBOT_ENABLED=false # Whether mentions should generate AI chatbot responses
CHATBOT_ORGANIC_CHANNEL_NAMES= # Optional comma-separated channel names where organic replies can occur; blank allows all channels
CHATBOT_ORGANIC_COOLDOWN_MINUTES=60 # Minimum minutes between organic replies per server
CHATBOT_ORGANIC_REPLY_CHANCE=0.01 # Chance from 0 to 1 that an eligible message gets an organic reply
OPENAI_API_KEY=? # OpenAI API key
OPENAI_MODEL=gpt-5.4-mini # Optional OpenAI model override for chatbot replies
OPENAI_PROMPT_ID=? # OpenAI prompt ID for chatbot replies
SUBMISSION_CHANNEL_NAME=? # Anonymous submissions channel name
